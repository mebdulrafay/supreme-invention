// ============================================================
// SERIAL & DATA (Thread-safe)
// ============================================================

void serialEvent(Serial myPort) {
  data = myPort.readStringUntil('.');
  if (data == null) return;
  
  data = data.substring(0, data.length() - 1).trim();
  
  if (data.startsWith("THREAT")) {
    handleThreat(data.substring(7));
  } else {
    handleNormalData(data);
  }
}

void handleNormalData(String data) {
  int comma = data.indexOf(",");
  if (comma < 0) return;
  
  try {
    rawAngle = int(data.substring(0, comma));
    rawDistance = int(data.substring(comma + 1));
    iAngle = rawAngle;
    iDistance = rawDistance;
    
    if (rawDistance > 0 && rawDistance < MAX_RANGE_CM) {
      addTrack(rawAngle, rawDistance, false);
    }
  } catch (Exception e) {
    // Invalid data
  }
}

void handleThreat(String threatData) {
  int comma = threatData.indexOf(",");
  if (comma < 0) return;
  
  try {
    int newThreatAngle = int(threatData.substring(0, comma));
    int newThreatDistance = int(threatData.substring(comma + 1));
    
    threatAngle = newThreatAngle;
    threatDistance = newThreatDistance;
    threatActive = true;
    threatStartTime = millis();
    
    iAngle = threatAngle;
    iDistance = threatDistance;
    
    addTrack(threatAngle, threatDistance, true);
    
    // Non-blocking TTS
    if (ttsReady && millis() - lastTTSTime > TTS_COOLDOWN) {
      lastTTSTime = millis();
      ttsReady = false;
      final String msg = "Hostile contact, bearing " + threatAngle + ", range " + threatDistance + " centimeters";
      
      ttsExecutor.execute(new Runnable() {
        public void run() {
          runTTS(msg);
          ttsReady = true;
        }
      });
    }
    
    println("THREAT: " + threatAngle + "° " + threatDistance + "cm");
  } catch (Exception e) {
    // Invalid threat data
  }
}

void addTrack(int angle, int distance, boolean isThreat) {
  synchronized(trackLock) {
    for (Track t : tracks) {
      if (abs(t.angle - angle) < 10 && abs(t.distance - distance) < 5) {
        t.update(angle, distance, radarCenterX, radarCenterY, MAX_RANGE_CM, radarRadius);
        t.isThreat = isThreat || t.isThreat;
        return;
      }
    }
    
    Track newTrack = new Track(tracks.size() + 1, angle, distance);
    newTrack.update(angle, distance, radarCenterX, radarCenterY, MAX_RANGE_CM, radarRadius);
    newTrack.isThreat = isThreat;
    tracks.add(newTrack);
    
    if (tracks.size() > 20) {
      tracks.remove(0);
    }
  }
}

void cleanupTracks(int now) {
  synchronized(trackLock) {
    for (int i = tracks.size() - 1; i >= 0; i--) {
      if (now - tracks.get(i).timestamp > TRACK_MAX_AGE) {
        tracks.remove(i);
      }
    }
  }
}

// ============================================================
// TTS (Runs in background thread)
// ============================================================

void runTTS(String msg) {
  try {
    String[] cmd;
    String os = System.getProperty("os.name").toLowerCase();
    
    if (os.contains("win")) {
      cmd = new String[]{"powershell", "-Command",
        "Add-Type -AssemblyName System.Speech; " +
        "$s = New-Object System.Speech.Synthesis.SpeechSynthesizer; " +
        "$s.Speak('" + msg + "')"};
    } else if (os.contains("mac")) {
      cmd = new String[]{"say", msg};
    } else {
      cmd = new String[]{"espeak", msg};
    }
    
    ProcessBuilder pb = new ProcessBuilder(cmd);
    pb.inheritIO();
    Process p = pb.start();
    p.waitFor();
    
    println("TTS completed: " + msg);
    
  } catch (Exception e) {
    println("TTS Error: " + e.getMessage());
  }
}

// ============================================================
// INPUT
// ============================================================

void keyPressed() {
  if (key == 'r' || key == 'R') {
    synchronized(trackLock) {
      tracks.clear();
    }
    println("Tracks reset");
  }
  if (key == 't' || key == 'T') {
    threatActive = true;
    threatStartTime = millis();
    threatAngle = int(random(180));
    threatDistance = int(random(5, 35));
    addTrack(threatAngle, threatDistance, true);
    
    if (ttsReady && millis() - lastTTSTime > TTS_COOLDOWN) {
      lastTTSTime = millis();
      ttsReady = false;
      final String msg = "Hostile contact, bearing " + threatAngle + ", range " + threatDistance + " centimeters";
      ttsExecutor.execute(new Runnable() {
        public void run() {
          runTTS(msg);
          ttsReady = true;
        }
      });
    }
  }
  if (key == 's' || key == 'S') {
    ttsReady = !ttsReady;
  }
}

// ============================================================
// CLASSES
// ============================================================

class Track {
  int id;
  int angle;
  int distance;
  volatile int timestamp;
  volatile boolean isThreat;
  ArrayList<PVector> history;
  
  Track(int id, int angle, int distance) {
    this.id = id;
    this.angle = angle;
    this.distance = distance;
    this.timestamp = millis();
    this.isThreat = false;
    this.history = new ArrayList<PVector>();
  }
  
  void update(int newAngle, int newDistance, float cx, float cy, int maxRange, float maxRadius) {
    this.angle = newAngle;
    this.distance = newDistance;
    this.timestamp = millis();
    
    float r = map(newDistance, 0, maxRange, 0, maxRadius);
    float a = radians(newAngle);
    float x = cx + cos(a) * r;
    float y = cy - sin(a) * r;
    
    history.add(new PVector(x, y));
    if (history.size() > 10) {
      history.remove(0);
    }
  }
}

class Threat {
  int angle, distance, timestamp;
  Threat(int a, int d, int t) {
    angle = a; distance = d; timestamp = t;
  }
}

// ============================================================
// CLEANUP ON EXIT
// ============================================================

void stop() {
  ttsExecutor.shutdown();
  super.stop();
}
